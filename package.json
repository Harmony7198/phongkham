{
  "name": "phong-kham-mini",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "preview:test": "vite preview --host 127.0.0.1 --port 4173",

    "test": "vitest",

    "test:unit": "vitest run tests/unit",

    "test:business": "vitest run tests/business",

    "test:coverage": "vitest run --coverage",

    "test:e2e": "playwright test",

    "test:e2e:ui": "playwright test --ui",

    "test:e2e:report": "playwright show-report",

    "test:all": "npm run test:unit && npm run test:business && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@vitest/coverage-v8": "^3.2.4",
    "vite": "^7.1.0",
    "vitest": "^3.2.4"
  }
}